
@{
    Layout = "_DashboardLayout";
}
@model List<Product>

    <h3>لوحة التحكم لإضافة المنتجات </h3>

    <div class="container mt-4">
        <div class="card">
            <div class="card-header">
                <h5>
                    <i class="bi bi-plus-circle-fill"></i> إضافة منتج جديد
                </h5>
            </div>

        <div class="card-body">
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label class="form-label">اختر الفئة</label>
                        <select class="form-select" name="CategoryId">
                            @foreach(var item in ViewBag.categories)
                            {
                                <option value="@item.Id">
                                    @item.Name
                                </option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">اسم المنتج</label>
                        <input type="text"name="Name" placeholder="أدخل اسم المنتج" class="form-control" />
                        <span asp-validation-for="@Model.First().Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">سعر المنتج</label>
                        <input type="number" name="Price" step="0.01" placeholder="أدخل سعر المنتج" class="form-control" />
                        <span asp-validation-for="@Model.First().Price" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">ارفق الصورة</label>
                        <input name="ImageFile" type="file" class="form-control" accept="image/*" />
                        @if (Model != null && Model.Any())
                        {   
                            <span asp-validation-for="@Model.First().ImageFile" class="text-danger"></span>
                        }
                    </div>
                    
                    <div class="mb-3">
                        <button class="btn btn-info text-white px-4">حفظ المنتج</button>
                        <a asp-action="Index" class="btn btn-secondary px-4">إلغاء</a>
                    </div>
                </form>
            </div>
        </div>

    </div>

    
    <div class="card mt-5">
        <div class="card-body">
            <div class="card mb-3 border-0 bg-light p-3 shadow-sm">
                <form method="get" asp-action="Index" class="row g-3 align-items-end">
                    <div class="col-md-9">
                        <label class="form-label small fw-bold text-secondary">ابحث باسم المنتج</label>
                        <input type="text" name="searchTerm" value="@ViewBag.CurrentSearch" placeholder="اكتب اسم المنتج الذي تريد البحث عنه..." class="form-control" />
                    </div>
                    <div class="col-md-3 d-flex gap-2">
                        <button type="submit" class="btn btn-info text-white w-100 fw-bold">
                            <i class="bi bi-search"></i> بحث
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">إلغاء</a>
                    </div>
                </form>
            </div>
            
            <table class="table">
                <thead>
                    <tr>
                        <td>#</td>
                        <td>اسم المنتج</td>
                        <td>سعر المنتج</td>
                        <td>صورة المنتج </td>
                        <td>الفئة </td>
                        <td colspan="2">الإجراءات</td>
                        
                    </tr>
                </thead>

                <tbody>
                    @if(Model == null)
                    {
                        <tr>
                            <td> لا توجد بيانات</td>
                        </tr>
                    }
                    else
                    {
                        @foreach(var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td>@item.Name</td>
                                <td>@item.Price</td>
                                <td>
                                    <img src="~/images/@item.Image"
                                    alt="@item.Name"
                                    width="50" 
                                    height="50"
                                    class="rounded"
                                    style="object-fit: cover;"/>
                                </td>   
                                <td>@item.category.Name</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" 
                                    class="btn btn-sm btn-outline-success mx-1 rounded-2">
                                    <i class="bi bi-pencil-square text-success"></i></a>
                                </td>
                                <td>
                                    <a asp-action="Delete" asp-route-id="@item.Id" 
                                    class="btn btn-sm btn-outline-danger mx-1 rounded-2"
                                    onclick="return confirm('هل انت متأكد من حذف هذا المنتج نهائيا؟')">
                                    <i class="bi bi-trash text-danger"></i></a>
                                </td>
                        
                            </tr>
                        }
                    }
                </tbody>

            </table>
        </div>
    </div>
    